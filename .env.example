# Environment Variables for Dynamic Build Environment

# Application Configuration
PORT=3000
NODE_ENV=development
BUILD_TIER=dev

# MCP Configuration
MCP_ACCESS_POINT_COUNT=4
MCP_MESSAGE_QUEUE_SIZE=1000
MCP_PING_INTERVAL=10000

# GIS Configuration
GIS_DEFAULT_COORDINATE_SYSTEM=WGS84
GIS_SIGNAL_PROCESSING_INTERVAL=5000
GIS_MAX_SIGNAL_HISTORY=100

# Agent Portal Configuration
AGENT_PORTAL_MAX_SESSIONS=1000
AGENT_TRACE_RETENTION_HOURS=24
AGENT_METRICS_UPDATE_INTERVAL=10000

# MGRS Configuration
MGRS_PING_INTERVAL=30000
MGRS_GRID_CLEANUP_INTERVAL=300000
MGRS_DEFAULT_PRECISION=5

# Security Configuration
AUTH_TOKEN_EXPIRY=3600
ENABLE_SSL=false
CORS_ORIGIN=*

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json