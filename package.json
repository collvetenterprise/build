{
  "name": "ai-phone-gateway",
  "version": "1.0.0",
  "description": "AI-powered phone server and internet gateway with intelligent automation",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "build": "npm run lint && npm test",
    "docker:build": "docker build -t ai-phone-gateway .",
    "docker:run": "docker run -p 8080:8080 -p 5060:5060 ai-phone-gateway"
  },
  "keywords": [
    "voip",
    "sip",
    "phone-server",
    "internet-gateway",
    "ai",
    "machine-learning",
    "automation",
    "network-optimization"
  ],
  "author": "collvetenterprise",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "ws": "^8.14.2",
    "axios": "^1.5.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "winston": "^3.10.0",
    "config": "^3.3.9",
    "redis": "^4.6.8",
    "mongodb": "^6.1.0",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.49.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/collvetenterprise/build.git"
  },
  "bugs": {
    "url": "https://github.com/collvetenterprise/build/issues"
  },
  "homepage": "https://github.com/collvetenterprise/build#readme"
}