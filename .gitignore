*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# System files
.DS_Store
Thumbs.db

# Logs and data
logs/
*.log
data/
*.db
*.sqlite
*.sqlite3

